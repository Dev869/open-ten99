rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Deny all access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------------------------
    // Helper functions
    // ---------------------------------------------------------------------------

    // Returns true for Google Sign-In users (contractors).
    // Firebase stores sign-in provider in token.firebase.sign_in_provider.
    function isContractor() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    // Returns true if a document is explicitly owned by the current user.
    // Docs without an ownerId field are NOT readable — every write path stamps
    // ownerId, so any missing-ownerId doc is treated as unowned rather than
    // falling back to a legacy allow-all.
    function isOwner(data) {
      return data.ownerId == request.auth.uid;
    }

    // For writes: the incoming document must claim the current user as owner.
    function claimsOwnership() {
      return request.resource.data.ownerId == request.auth.uid;
    }

    // ---------------------------------------------------------------------------
    // Clients collection
    // ---------------------------------------------------------------------------
    // Only contractors can manage clients. Scoped to the owning contractor.
    match /clients/{clientId} {
      allow read: if isContractor() && isOwner(resource.data);
      allow create: if isContractor() && claimsOwnership();
      allow update: if isContractor()
        && isOwner(resource.data)
        && claimsOwnership();

      // Delete: contractor owns the doc
      allow delete: if isContractor() && isOwner(resource.data);
    }

    // ---------------------------------------------------------------------------
    // Projects collection
    // ---------------------------------------------------------------------------
    match /projects/{projectId} {
      allow read: if isContractor() && isOwner(resource.data);
      allow create: if isContractor() && claimsOwnership();
      // Update: contractor owns the doc AND must claim ownership
      allow update: if isContractor()
        && isOwner(resource.data)
        && claimsOwnership();
      // Delete: contractor owns the doc
      allow delete: if isContractor() && isOwner(resource.data);
    }

    // ---------------------------------------------------------------------------
    // Work items collection
    // ---------------------------------------------------------------------------
    // Contractors: full CRUD on their own items.
    // Portal clients: read-only access scoped to work items belonging to their
    //   clientId. The clientId claim is set in the custom token by the Cloud
    //   Function that issues magic-link tokens. Portal users cannot write.
    match /workItems/{workItemId} {
      // Contractor read: owns the item
      allow read: if isContractor() && isOwner(resource.data);

      // Portal client read: authenticated non-contractor whose clientId claim
      // matches the item's clientId field.
      allow read: if request.auth != null
        && !isContractor()
        && request.auth.token.clientId != null
        && resource.data.clientId == request.auth.token.clientId;

      // Portal client update: can only set clientNotes, clientApproval,
      // clientApprovalDate on their own work items — nothing else.
      allow update: if request.auth != null
        && !isContractor()
        && request.auth.token.clientId != null
        && resource.data.clientId == request.auth.token.clientId
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['clientNotes', 'clientApproval', 'clientApprovalDate', 'updatedAt']);

      // Contractor create: must set themselves as owner
      allow create: if isContractor() && claimsOwnership();

      // Contractor update: owns the doc AND must claim ownership
      allow update: if isContractor()
        && isOwner(resource.data)
        && claimsOwnership();

      // Contractor delete: owns the doc
      allow delete: if isContractor() && isOwner(resource.data);
    }

    // ---------------------------------------------------------------------------
    // Apps collection
    // ---------------------------------------------------------------------------
    // Only contractors can manage apps. Scoped to the owning contractor.
    match /apps/{appId} {
      allow read: if isContractor() && isOwner(resource.data);
      allow create: if isContractor() && claimsOwnership();
      // Update: contractor owns the doc AND must claim ownership
      allow update: if isContractor()
        && isOwner(resource.data)
        && claimsOwnership();
      // Delete: contractor owns the doc
      allow delete: if isContractor() && isOwner(resource.data);
    }

    // ---------------------------------------------------------------------------
    // Integrations: owner can read, server writes only
    // ---------------------------------------------------------------------------
    match /integrations/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    // ---------------------------------------------------------------------------
    // GitHub activity subcollection: owner can read, server writes only
    // ---------------------------------------------------------------------------
    match /apps/{appId}/github/{activityId} {
      allow read: if isContractor() && isOwner(
        get(/databases/$(database)/documents/apps/$(appId)).data
      );
      allow write: if false;
    }

    // ---------------------------------------------------------------------------
    // Settings collection: user-scoped by document ID
    // ---------------------------------------------------------------------------
    match /settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ---------------------------------------------------------------------------
    // Profiles collection: user-scoped by document ID
    // ---------------------------------------------------------------------------
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ---------------------------------------------------------------------------
    // Vault: owner-only — credentials are client-side encrypted
    // ---------------------------------------------------------------------------
    match /vaults/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /credentials/{credentialId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ---------------------------------------------------------------------------
    // Teams: collaborative workspaces
    // ---------------------------------------------------------------------------
    // Team document: any authenticated member can read. Only owner can update/delete.
    // Create: any contractor can create a team (they become owner).
    match /teams/{teamId} {
      // Only the team owner or a member of the team can read team info
      allow read: if request.auth != null
        && (resource.data.ownerId == request.auth.uid
            || exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)));

      // Create: contractor sets themselves as owner
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      // Update: only the owner
      allow update: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      // Delete: only the owner
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      // Members subcollection: readable by the team owner or any team member
      match /members/{memberId} {
        allow read: if request.auth != null
          && (get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid
              || exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)));

        // Owner can manage all members
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid;

        // Members can update their own profile fields (not role)
        allow update: if request.auth != null
          && request.auth.uid == memberId
          && request.resource.data.role == resource.data.role;
      }

      // Invites subcollection: readable by the team owner or any team member
      match /invites/{inviteId} {
        allow read: if request.auth != null
          && (get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid
              || exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid)));

        allow create: if request.auth != null
          && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid;

        // Owner can update any invite field; invitee can only update the status field
        allow update: if request.auth != null
          && (get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid
              || (resource.data.email == request.auth.token.email
                  && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])));

        allow delete: if request.auth != null
          && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid;
      }
    }

    // ---------------------------------------------------------------------------
    // Finance Module (Phase 2-3)
    // ---------------------------------------------------------------------------

    // connectedAccounts — client can read/write display metadata (no secrets)
    match /connectedAccounts/{docId} {
      allow read: if isContractor()
        && resource.data.ownerId == request.auth.uid;
      allow create: if isContractor()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isContractor()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isContractor()
        && resource.data.ownerId == request.auth.uid;
    }

    // _secrets — deny ALL client access, admin SDK only
    match /_secrets/{document=**} {
      allow read, write: if false;
    }

    // transactions — standard ownerId pattern
    match /transactions/{docId} {
      allow read: if isContractor()
        && resource.data.ownerId == request.auth.uid;
      allow create: if isContractor()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isContractor()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isContractor()
        && resource.data.ownerId == request.auth.uid;
    }

    match /emailTemplates/{templateId} {
      allow read: if isContractor()
        && resource.data.ownerId == request.auth.uid;
      allow create: if isContractor()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isContractor()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isContractor()
        && resource.data.ownerId == request.auth.uid;
    }

    match /receipts/{receiptId} {
      allow read: if isContractor() && resource.data.ownerId == request.auth.uid;
      allow create: if isContractor() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isContractor() && resource.data.ownerId == request.auth.uid
                     && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isContractor() && resource.data.ownerId == request.auth.uid;
    }

    // magicLinks — contractors create, Cloud Functions verify
    match /magicLinks/{linkId} {
      allow read: if false; // only server-side via admin SDK
      allow create: if isContractor() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if false; // only server-side
    }

    // timeEntries — standard ownerId pattern
    match /timeEntries/{entryId} {
      allow read: if isContractor() && resource.data.ownerId == request.auth.uid;
      allow create: if isContractor() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isContractor() && resource.data.ownerId == request.auth.uid
                     && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isContractor() && resource.data.ownerId == request.auth.uid;
    }

    match /mileageTrips/{tripId} {
      allow read: if isContractor() && resource.data.ownerId == request.auth.uid;
      allow create: if isContractor() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isContractor() && resource.data.ownerId == request.auth.uid
                     && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isContractor() && resource.data.ownerId == request.auth.uid;
    }

    match /insights/{userId} {
      allow read: if isContractor() && userId == request.auth.uid;
      allow write: if false;
    }
  }
}
