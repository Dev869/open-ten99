rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Deny all access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Clients collection: authenticated users only
    match /clients/{clientId} {
      allow read, write: if request.auth != null;
    }

    // Projects collection: authenticated users only
    match /projects/{projectId} {
      allow read, write: if request.auth != null;
    }

    // Work items collection: authenticated users only
    match /workItems/{workItemId} {
      allow read, write: if request.auth != null;
    }

    // Settings collection: authenticated user can only access their own settings doc
    match /settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Profiles collection: authenticated user can only access their own profile doc
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Vault: owner-only access — credentials are client-side encrypted
    match /vaults/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /credentials/{credentialId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
