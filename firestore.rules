rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Deny all access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------------------------
    // Helper functions
    // ---------------------------------------------------------------------------

    // Returns true for Google Sign-In users (contractors).
    // Firebase stores sign-in provider in token.firebase.sign_in_provider.
    function isContractor() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    // Returns true if a document is owned by the current user.
    // Migration-friendly: if ownerId is absent (legacy data), the rule passes so
    // existing records remain accessible while we backfill the field.
    function isOwnerOrLegacy(data) {
      return !('ownerId' in data) || data.ownerId == request.auth.uid;
    }

    // For writes: the incoming document must claim the current user as owner.
    function claimsOwnership() {
      return request.resource.data.ownerId == request.auth.uid;
    }

    // ---------------------------------------------------------------------------
    // Clients collection
    // ---------------------------------------------------------------------------
    // Only contractors can manage clients. Scoped to the owning contractor.
    // Legacy documents without ownerId remain readable/updatable until backfilled.
    match /clients/{clientId} {
      // Read: contractor + (their doc or legacy doc without ownerId)
      allow read: if isContractor() && isOwnerOrLegacy(resource.data);

      // Create: contractor must set themselves as owner
      allow create: if isContractor() && claimsOwnership();

      // Update: contractor must own the existing doc (or it's legacy), and cannot
      // change ownerId to someone else
      allow update: if isContractor()
        && isOwnerOrLegacy(resource.data)
        && (!('ownerId' in request.resource.data)
            || request.resource.data.ownerId == request.auth.uid);

      // Delete: contractor must own the existing doc (or it's legacy)
      allow delete: if isContractor() && isOwnerOrLegacy(resource.data);
    }

    // ---------------------------------------------------------------------------
    // Projects collection
    // ---------------------------------------------------------------------------
    match /projects/{projectId} {
      allow read: if isContractor() && isOwnerOrLegacy(resource.data);
      allow create: if isContractor() && claimsOwnership();
      allow update: if isContractor()
        && isOwnerOrLegacy(resource.data)
        && (!('ownerId' in request.resource.data)
            || request.resource.data.ownerId == request.auth.uid);
      allow delete: if isContractor() && isOwnerOrLegacy(resource.data);
    }

    // ---------------------------------------------------------------------------
    // Work items collection
    // ---------------------------------------------------------------------------
    // Contractors: full CRUD on their own items (or legacy items).
    // Portal clients: read-only access scoped to work items belonging to their
    //   clientId. The clientId claim is set in the custom token by the Cloud
    //   Function that issues magic-link tokens. Portal users cannot write.
    match /workItems/{workItemId} {
      // Contractor read: owns the item or it's a legacy item
      allow read: if isContractor() && isOwnerOrLegacy(resource.data);

      // Portal client read: authenticated non-contractor whose clientId claim
      // matches the item's clientId field. Read-only — no writes from portal.
      allow read: if request.auth != null
        && !isContractor()
        && request.auth.token.clientId != null
        && resource.data.clientId == request.auth.token.clientId;

      // Contractor create: must set themselves as owner
      allow create: if isContractor() && claimsOwnership();

      // Contractor update: must own the existing item and cannot reassign ownership
      allow update: if isContractor()
        && isOwnerOrLegacy(resource.data)
        && (!('ownerId' in request.resource.data)
            || request.resource.data.ownerId == request.auth.uid);

      // Contractor delete: must own the existing item
      allow delete: if isContractor() && isOwnerOrLegacy(resource.data);
    }

    // ---------------------------------------------------------------------------
    // Apps collection
    // ---------------------------------------------------------------------------
    // Only contractors can manage apps. Scoped to the owning contractor.
    match /apps/{appId} {
      allow read: if isContractor() && isOwnerOrLegacy(resource.data);
      allow create: if isContractor() && claimsOwnership();
      allow update: if isContractor()
        && isOwnerOrLegacy(resource.data)
        && (!('ownerId' in request.resource.data)
            || request.resource.data.ownerId == request.auth.uid);
      allow delete: if isContractor() && isOwnerOrLegacy(resource.data);
    }

    // ---------------------------------------------------------------------------
    // Settings collection: user-scoped by document ID
    // ---------------------------------------------------------------------------
    match /settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ---------------------------------------------------------------------------
    // Profiles collection: user-scoped by document ID
    // ---------------------------------------------------------------------------
    match /profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ---------------------------------------------------------------------------
    // Vault: owner-only — credentials are client-side encrypted
    // ---------------------------------------------------------------------------
    match /vaults/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /credentials/{credentialId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ---------------------------------------------------------------------------
    // Teams: collaborative workspaces
    // ---------------------------------------------------------------------------
    // Team document: any authenticated member can read. Only owner can update/delete.
    // Create: any contractor can create a team (they become owner).
    match /teams/{teamId} {
      // Anyone authenticated can read team info (needed to check membership)
      allow read: if request.auth != null;

      // Create: contractor sets themselves as owner
      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      // Update: only the owner
      allow update: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      // Delete: only the owner
      allow delete: if request.auth != null
        && resource.data.ownerId == request.auth.uid;

      // Members subcollection: readable by any authed user,
      // writable by team owner or admins (admin check requires reading member doc)
      match /members/{memberId} {
        allow read: if request.auth != null;

        // Owner can manage all members
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid;

        // Members can update their own profile fields (not role)
        allow update: if request.auth != null
          && request.auth.uid == memberId
          && request.resource.data.role == resource.data.role;
      }

      // Invites subcollection: readable by team members,
      // writable by owner/admins
      match /invites/{inviteId} {
        allow read: if request.auth != null;

        allow create: if request.auth != null
          && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid;

        allow update: if request.auth != null;

        allow delete: if request.auth != null
          && get(/databases/$(database)/documents/teams/$(teamId)).data.ownerId == request.auth.uid;
      }
    }

    // ---------------------------------------------------------------------------
    // Finance Module (Phase 2-3)
    // ---------------------------------------------------------------------------

    // connectedAccounts — client can read/write display metadata (no secrets)
    match /connectedAccounts/{docId} {
      allow read: if isContractor()
        && resource.data.ownerId == request.auth.uid;
      allow create: if isContractor()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isContractor()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isContractor()
        && resource.data.ownerId == request.auth.uid;
    }

    // _secrets — deny ALL client access, admin SDK only
    match /_secrets/{document=**} {
      allow read, write: if false;
    }

    // transactions — standard ownerId pattern
    match /transactions/{docId} {
      allow read: if isContractor()
        && resource.data.ownerId == request.auth.uid;
      allow create: if isContractor()
        && request.resource.data.ownerId == request.auth.uid;
      allow update: if isContractor()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == request.auth.uid;
      allow delete: if isContractor()
        && resource.data.ownerId == request.auth.uid;
    }
  }
}
