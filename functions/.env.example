# Google AI API key for Gemini-powered email parsing
GOOGLE_AI_API_KEY=your-google-ai-api-key-here

# Secret used to validate inbound Postmark webhook requests
POSTMARK_WEBHOOK_SECRET=your-postmark-webhook-secret-here

# GitHub OAuth integration secrets
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# SendGrid API key for outbound emails
SENDGRID_API_KEY=your-sendgrid-api-key
